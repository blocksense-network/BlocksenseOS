# Default environment variables for act
# These simulate the GitHub Actions environment variables

# GitHub environment
GITHUB_REPOSITORY=blocksense-network/BlocksenseOS
GITHUB_REPOSITORY_OWNER=blocksense-network
GITHUB_ACTOR=local-user

# Performance settings for local execution
MAX_WORKERS=2
MAX_MEMORY=4096

# Act-specific settings
ACT=true

# Attic configuration (missing in act environment)
ATTIC_CACHE=blocksense-public
TRUSTED_PUBLIC_KEYS=blocksense-public:OOgTc0ye1FONCiVHMrbpScc/HP+lX3uoU0EfwzX6ypE=
SUBSTITUTERS=https://cache.metacraft-labs.com/blocksense-public